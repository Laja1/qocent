"use client"

import { useState } from "react"
import { MatrixTable, type MatrixColumn, type MatrixRow } from "./matrix-table"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"

export function MatrixTableExample() {
  const [columns, setColumns] = useState<MatrixColumn[]>([
    { id: "db1", label: "DATABASE 1", description: "Primary" },
    { id: "db2", label: "DATABASE 2", description: "Secondary" },
    { id: "db3", label: "DATABASE 3", description: "Backup" },
    { id: "db4", label: "DATABASE 4", description: "Archive" },
  ])

  const [rows, setRows] = useState<MatrixRow[]>([
    {
      id: "name",
      label: "Name",
      description: "Database name identifier",
      cells: {
        db1: { value: "production-db", editable: true },
        db2: { value: "staging-db", editable: true },
        db3: { value: "backup-db", editable: true },
        db4: { value: "archive-db", editable: true },
      },
    },
    {
      id: "description",
      label: "Description",
      description: "Database description",
      cells: {
        db1: { value: "Main production database", editable: true },
        db2: { value: "Staging environment database", editable: true },
        db3: { value: "Backup database for disaster recovery", editable: true },
        db4: { value: "Long-term archive storage", editable: true },
      },
    },
    {
      id: "cidrblock",
      label: "CidrBlock",
      description: "Network CIDR block",
      cells: {
        db1: { value: "10.0.1.0/24", editable: true },
        db2: { value: "10.0.2.0/24", editable: true },
        db3: { value: "10.0.3.0/24", editable: true },
        db4: { value: "10.0.4.0/24", editable: true },
      },
    },
    {
      id: "vpcid",
      label: "VpcId",
      description: "VPC identifier",
      cells: {
        db1: { value: "vpc-12345", editable: true },
        db2: { value: "vpc-23456", editable: true },
        db3: { value: "vpc-34567", editable: true },
        db4: { value: "vpc-45678", editable: true },
      },
    },
    {
      id: "type",
      label: "Type",
      description: "Database type",
      cells: {
        db1: { value: "PostgreSQL", editable: true },
        db2: { value: "PostgreSQL", editable: true },
        db3: { value: "PostgreSQL", editable: true },
        db4: { value: "PostgreSQL", editable: true },
      },
    },
  ])

  const handleCellChange = (rowId: string, columnId: string, value: string) => {
    setRows((prevRows) =>
      prevRows.map((row) =>
        row.id === rowId
          ? {
              ...row,
              cells: {
                ...row.cells,
                [columnId]: { ...row.cells[columnId], value },
              },
            }
          : row,
      ),
    )
  }

  const handleAddColumn = () => {
    const newColumnId = `db${columns.length + 1}`
    const newColumn: MatrixColumn = {
      id: newColumnId,
      label: `DATABASE ${columns.length + 1}`,
      description: "New DB",
    }

    setColumns([...columns, newColumn])

    // Add empty cells for the new column in all rows
    setRows((prevRows) =>
      prevRows.map((row) => ({
        ...row,
        cells: {
          ...row.cells,
          [newColumnId]: { value: "", editable: true },
        },
      })),
    )
  }

  const handleRemoveColumn = (columnId: string) => {
    setColumns(columns.filter((col) => col.id !== columnId))
    setRows((prevRows) =>
      prevRows.map((row) => {
        const { [columnId]: removed, ...remainingCells } = row.cells
        return { ...row, cells: remainingCells }
      }),
    )
  }

  const handleAddRow = () => {
    const newRowId = `param${rows.length + 1}`
    const newCells: Record<string, { value: string; editable: boolean }> = {}

    columns.forEach((col) => {
      newCells[col.id] = { value: "", editable: true }
    })

    const newRow: MatrixRow = {
      id: newRowId,
      label: `Parameter ${rows.length + 1}`,
      description: "New parameter",
      cells: newCells,
    }

    setRows([...rows, newRow])
  }

  const handleRemoveRow = (rowId: string) => {
    setRows(rows.filter((row) => row.id !== rowId))
  }

  const handleEditColumn = (columnId: string, newLabel: string) => {
    setColumns((prevColumns) => prevColumns.map((col) => (col.id === columnId ? { ...col, label: newLabel } : col)))
  }

  const handleEditRow = (rowId: string, newLabel: string) => {
    setRows((prevRows) => prevRows.map((row) => (row.id === rowId ? { ...row, label: newLabel } : row)))
  }

  return (
    <div className="space-y-6">
      <Card>
        <CardHeader>
          <CardTitle>Database Configuration Matrix</CardTitle>
        </CardHeader>
        <CardContent>
          <MatrixTable
            title="Database Parameters Comparison"
            description="Compare configuration parameters across different database environments"
            topLeftHeader="PARAMETERS"
            secondRowLeftHeader="PARAMETER CODE"
            columns={columns}
            rows={rows}
            onCellChange={handleCellChange}
            onAddColumn={handleAddColumn}
            onRemoveColumn={handleRemoveColumn}
            onAddRow={handleAddRow}
            onRemoveRow={handleRemoveRow}
            onEditColumn={handleEditColumn}
            onEditRow={handleEditRow}
            allowAddColumns={true}
            allowRemoveColumns={true}
            allowAddRows={true}
            allowRemoveRows={true}
            allowEditHeaders={true}
            maxHeight="500px"
            stickyHeaders={true}
          />
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle>Read-Only Matrix Example</CardTitle>
        </CardHeader>
        <CardContent>
          <MatrixTable
            title="Server Specifications"
            description="Read-only comparison of server specifications"
            topLeftHeader="SPECIFICATIONS"
            secondRowLeftHeader="SPEC CODE"
            columns={[
              { id: "server1", label: "WEB SERVER", description: "Frontend" },
              { id: "server2", label: "API SERVER", description: "Backend" },
              { id: "server3", label: "DB SERVER", description: "Database" },
            ]}
            rows={[
              {
                id: "cpu",
                label: "CPU Cores",
                cells: {
                  server1: { value: "4 cores", editable: false },
                  server2: { value: "8 cores", editable: false },
                  server3: { value: "16 cores", editable: false },
                },
              },
              {
                id: "memory",
                label: "Memory",
                cells: {
                  server1: { value: "8 GB", editable: false },
                  server2: { value: "16 GB", editable: false },
                  server3: { value: "64 GB", editable: false },
                },
              },
              {
                id: "storage",
                label: "Storage",
                cells: {
                  server1: { value: "100 GB SSD", editable: false },
                  server2: { value: "500 GB SSD", editable: false },
                  server3: { value: "2 TB SSD", editable: false },
                },
              },
            ]}
            maxHeight="400px"
            stickyHeaders={true}
          />
        </CardContent>
      </Card>
    </div>
  )
}
